{
  "schemaVersion": 1,
  "id": "archon",
  "version": "${version}",

  "name": "Archon Renewed",
  "description": "Sorcery, Necromancy, Bosses, and More, now Renewed!",
  "authors": [
    "Stalemated",
    "Safro (Archon original dev)"
  ],
  "contact": {
    "homepage": "https://curseforge.com/minecraft/mc-mods/archon-renewed",
    "sources": "https://github.com/Stalemated/Archon-Renewed",
    "issues": "https://github.com/Stalemated/Archon-Renewed/issues"
  },

  "license": "GNU GPLv3",
  "icon": "assets/archon/icon.png",

  "environment": "*",
  "entrypoints": {
    "main": [
      "safro.archon.Archon"
    ],
    "client": [
      "safro.archon.ArchonClient"
    ],
    "cardinal-components-entity": [
      "safro.archon.registry.ComponentsRegistry"
    ],
    "rei_client": [
      "safro.archon.compat.rei.ArchonREIPlugin"
    ],
    "emi": [
      "safro.archon.compat.emi.ArchonEmiPlugin"
    ]
  },
  "mixins": [
    "archon.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.14.22",
    "fabric": "*",
    "minecraft": "1.20.x",
    "java": ">=17",
    "spell_power": ">=0.11.0+1.20.1"
  },
  "custom": {
    "cardinal-components": [
      "archon:mana",
      "archon:scroll",
      "archon:spell"
    ]
  },
  "accessWidener": "archon.accesswidener"
}
